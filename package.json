{
  "name": "@hailbytes/mcp-security-scanner",
  "version": "0.0.1",
  "description": "Scans MCP server configurations for common security issues: overprivileged tools, missing auth, prompt injection surface, unsafe defaults.",
  "type": "module",
  "license": "MIT",
  "author": "HailBytes, LLC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HailBytes/mcp-security-scanner.git"
  },
  "bugs": {
    "url": "https://github.com/HailBytes/mcp-security-scanner/issues"
  },
  "homepage": "https://hailbytes.com/mcp",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "security-scanner",
    "ai-security",
    "llm-security",
    "prompt-injection",
    "mcp-server",
    "hailbytes"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mcp-security-scanner": "./dist/cli.js"
